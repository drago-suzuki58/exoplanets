<%
var siteBase = (typeof basePath !== 'undefined' && basePath) ? String(basePath).replace(/\/$/, '') : '';
%>
<!DOCTYPE html>
<html>
    <head>
        <meta charset="utf-8">
	<meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>Exobirthdays. More planets, more birthdays.</title>
	<script src="https://ajax.googleapis.com/ajax/libs/jquery/1.10.2/jquery.min.js"></script>
	<script src="<%= siteBase %>/jquery.html5-placeholder-shim.js"></script>
	<link href='https://fonts.googleapis.com/css?family=Voltaire' rel='stylesheet' type='text/css'>
	<link rel="stylesheet" href="<%= siteBase %>/main.css" />
	<script type="text/javascript" src="<%= siteBase %>/exo.js"></script>
	<script type="text/javascript" src="<%= siteBase %>/editor.js"></script>
	<script type="text/javascript" src="<%= siteBase %>/ejs_production.js"></script>
    </head>
    <body>
      <div class="all_page">
      <div class="talky">
      <h1>Where is your birthday today?</h1>

      <p class="hook sig">
      </p>

      <div class="container">
        <form>
          <input type="tel" id="birth_date_all" class="date_all" autofocus spellcheck=false value="YYYY.MM.DD" />
        </form>
        <p>
          <span>Enter birth date to compute exoplanet birthdays.</span>
        </p>
      </div>

    <div id="date_string sig"></div>
    </div>
    <div id="result"></div>

      <div class="talky">
	<div class="faq">
	  <h3>What is a birthday?</h3>

	  <p>
	    The instant you were born, every planet in the universe was at a
	    particular point of its orbit.  Every time a planet circles its
	    sun and returns to that some point, one of its years have passed,
	    and it is PARTY TIME.
	    If you have a different definition of a birthday, 
	    perhaps an Earth-centric one,
	    then too bad but we will still invite you to ALL OUR MANY PARTIES.
	  </p>

	  <h3>Have you factored in relativity?</h3>

	  <p>
	    There's a reason that I'm not going to tell you
	    where in its orbit each planet was at your birth, just when it will
	    get back there again.
	  </p>

	  <h3>How many exoplanets are known?</h3>

	  <p>
	    Check out the <a href="http://exoplanet.eu/catalog/">exoplanet catalog</a>. &ldquo;<a href='https://xkcd.com/1298/'>It's a beautiful day in the neighborhood</a>.&rdquo;  
	  </p>

	  <h3>Aren't there exoplanets with very snappy orbits?</h3>

	  <p>
	    Yes.  Yes there are. You are surprisingly well informed.
	    These are known as the PARTY PLANETS where it is your 
	    birthday pretty much every other day.  I've excluded
	    them from the list here for now since frankly your
	    age on these planets may be demoralizing.
	  </p>

	  <h3>Is your math correct?</h3>

	  <p>
	    Oh absolutely.  Take my word for it.  Has the internet
	    ever lied to you?  Bug reports to <a href="https://github.com/paulfitz/exoplanets">github</a> and snarky comments to <a href="https://twitter.com/fitzyfitzyfitzy">twitter</a> please.
	  </p>

	  <p>
	    This instance is maintained at <a href="https://github.com/drago-suzuki58/exoplanets">github.com/drago-suzuki58/exoplanets</a> as a fork of the original project.
	  </p>

	</div>
      </div>


<script>

 var siteBase = <%- JSON.stringify(siteBase) %>;
 function numberFromPath(value) {
   var result = parseInt(value, 10);
   return isNaN(result) ? null : result;
 }
 function dateFromPath() {
   var path = window.location.pathname || "/";
   if (siteBase && (path === siteBase || path.indexOf(siteBase + '/') === 0)) {
     path = path.slice(siteBase.length) || "/";
   }
   var parts = path.split('/').filter(function(part) { return part.length > 0; }).map(function(part) {
     try {
       return decodeURIComponent(part);
     } catch (err) {
       return part;
     }
   });
   if (parts.length < 3) return null;
   var year = numberFromPath(parts[0]);
   var month = numberFromPath(parts[1]);
   var day = numberFromPath(parts[2]);
   if (year === null || month === null || day === null) return null;
   var result = { year: year, month: month, day: day };
   if (parts.length >= 6) {
     var nyear = numberFromPath(parts[3]);
     var nmonth = numberFromPath(parts[4]);
     var nday = numberFromPath(parts[5]);
     if (nyear !== null && nmonth !== null && nday !== null) {
       result.nyear = nyear;
       result.nmonth = nmonth;
       result.nday = nday;
     }
   } else if (parts.length >= 4) {
     result.name = parts[3];
   }
   return result;
 }
 var serverDate = <% if (date) { %>{
   year: <%= parseInt(date.year, 10) %>,
   month: <%= parseInt(date.month, 10) %>,
   day: <%= parseInt(date.day, 10) %>,
   name: <%- JSON.stringify(date.name || null) %>
   <% if (date.nyear) { %>,
   nyear: <%= parseInt(date.nyear, 10) %>,
   nmonth: <%= parseInt(date.nmonth, 10) %>,
   nday: <%= parseInt(date.nday, 10) %>
   <% } %>
 }<% } else { %>null<% } %>;
 var pathDate = dateFromPath();
 var initialDate = serverDate || pathDate;
 var urlName = "" + ((initialDate && initialDate.name) || "you");
 var urlNamePerson = (initialDate && initialDate.name && urlName.toLowerCase() !== 'you') ? 3 : 2;
 var exo_data = <%- JSON.stringify(exo) %>;
 var unit = new EJS({url: siteBase + '/unit.ejs'});
 var now = new Date(new Date().toDateString());

 $(function() {
   var update = null;
   var update_incomplete = null;
   var editor = new Editor($('#birth_date_all'), function(date) {
     if (update) { update(date); }
   },
 function() {
   if (update_incomplete) { update_incomplete(); }
 });


   var ticker = null;
   function animatePlanets() {
     $(".event").hide()
     function scan() {
        ticker = null;
        var lst = $(".event").each(function() {
          if (ticker==null && !$(this).is(':visible')) {
            $(this).show();
            ticker = setTimeout(scan, 200);
          }
        });
     }
     scan();
   }

   function applyDate(year,month,day,example,person,name) {
     var target = new Date(year,month-1,day);
     var x = new Exo(exo_data);
     var calc = x.compute(now,target);
     var page = $('#result');
     page.html(unit.render({ calc: calc, example: example, person: person, name: name }));
     animatePlanets();
     return target;
   }

   function setState(o,v) {
       var jo = $(o);
       if (v==1) {
	   jo.removeClass("bad");
	   jo.addClass("good");
       } else if (v==0) {
	   jo.removeClass("good");
	   jo.addClass("bad");
       } else {
	   jo.removeClass("good");
	   jo.removeClass("bad");
       }
   }

     var updateHasYear = false;
     var updateHasMonth = false;
     var updateHasDay = false;

     function scan(date) {
	 var page = $('#date_string');
	 page.html("");
	 var yy = date[0];
	 var mm = date[1];
	 var dd = date[2]
	 var year = parseFloat(yy);
	 var month = parseFloat(mm);
	 var day = parseFloat(dd);
 /*
	 if (isNaN(year)) {
	     year = 0;
	 }
	 if (isNaN(day)) {
	     day = 0;
	 }
	 if (isNaN(month)) {
	     var s = $('#birth_date_month').val() + " 1, 2000";
	     var d = new Date(s);
	     month = d.getMonth()+1;
	 }
	 var iyear = Math.floor(year+0.5);
	 var imonth = Math.floor(month+0.5);
	 var iday = Math.floor(day+0.5);
	 if (yy==""&&mm==""&&dd=="") return null;
	 var good = 0;
	 if (yy!="") { 
	     if (updateHasYear) {
		 if (iyear<1800 || iyear>2300) {
		     setState('#birth_date_all',0);
		     page.append("<span>The year looks strange</span>"); 
		 } else {
                     setState('#birth_date_all',1);
		     good++;
		 }
	     }
	 } else {
	     setState('#birth_date_all',-1);
	 }
	 if (mm!="") {
	     if (imonth<1 || imonth>12) {
		 imonth = Math.NaN;
	     }
	     if (updateHasMonth) {
		 if (isNaN(imonth)) {
		     page.append("<span>The month is odd</span>"); 
		 }
		 if (isNaN(imonth)) {
		     setState('#birth_date_all',0);
		 } else {
		     setState('#birth_date_all',1);
		     good++;
		 }
	     }
	 } else {
	     setState('#birth_date_month',-1);
	 }
	 if (dd!="") {
	     if (iday<1 || iday>31) {
		 iday = Math.NaN;
	     }
	     if (updateHasDay) {
		 if (isNaN(iday)) {
		     page.append("<span>The day is out of range</span>"); 
		 }
		 if (isNaN(iday)) {
		     setState('#birth_date_day',0);
		 } else {
		     setState('#birth_date_day',1);
		     good++;
		 }
	     }
	 } else {
	     setState('#birth_date_day',-1);
	 }
	 if (good<3) return null;
                     */
	 return { year: year, month: month, day: day };
     }

   update = function(date) {
       var goal = scan(date);
       if (goal==null) return;
       if (goal.month < 1 || goal.month > 12 || goal.day < 1 || goal.day > 31) {
         setState('#birth_date_all',0);
         return false;
       }
       var target = applyDate(goal.year,goal.month,goal.day,null,urlNamePerson,urlName);
       $("#date_string").html("");
       if (window.history) {
         if (urlName === 'you') {
           history.replaceState(null, null, siteBase + "/" + goal.year + "/" + goal.month + "/" + goal.day);
         } else {
           history.replaceState(null, null, siteBase + "/" + goal.year + "/" + goal.month + "/" + goal.day + "/" + encodeURIComponent(urlName));
         }
       }
       return false;
   };

   update_incomplete = function() {
     setState('#birth_date_all',-1);
   };

     if (initialDate) {
       if (initialDate.nyear) {
         now = new Date(initialDate.nyear, initialDate.nmonth - 1, initialDate.nday);
       }
       editor.setDate(initialDate.year, initialDate.month, initialDate.day);
     } else {
       var example = <%- JSON.stringify(people[0]) %>;
       applyDate(example.year,example.month,example.day,example,3,"Ursula K Le Guin");
     }
 });
</script>

      </div>
    </body>
</html>
